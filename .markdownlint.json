{
  "MD013": {
    "line_length": 500,
    "code_blocks": false,
    "tables": false,
    "headings": false
  },
  "MD033": {
    "allowed_elements": [
      "kbd",
      "br",
      "details",
      "summary",
      "img",
      "a",
      "sub",
      "sup"
    ]
  },
  "MD041": false,
  "MD025": {
    "front_matter_title": ""
  },
  "MD024": {
    "siblings_only": true
  },
  "MD007": {
    "indent": 2
  },
  "MD030": {
    "ul_single": 1,
    "ol_single": 1,
    "ul_multi": 1,
    "ol_multi": 1
  }
}
