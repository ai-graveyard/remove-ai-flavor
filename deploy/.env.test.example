# ====================================
# 测试环境配置文件
# ====================================

######## 环境与服务 ########
# env
ENV=test

# Docker 配置
DOCKER_REGISTRY=v2ai
IMAGE_PREFIX=remove-ai-flavor
IMAGE_SUFFIX=-test
VERSION=latest

# 容器和网络命名
CONTAINER_PREFIX=remove-ai-flavor
CONTAINER_SUFFIX=-test
NETWORK_NAME=remove-ai-flavor-network-test

# 前端构建参数
NEXT_PUBLIC_API_URL=http://localhost:8081
NEXT_PUBLIC_APP_URL=http://localhost:8081

# Nginx 配置
NGINX_PORT=8081
NGINX_SERVER_NAME=localhost

# 认证配置
AUTH_SECRET_KEY=C1H2A3G4E5N6T7_TEST
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_IS_DEBUG=True

# API 配置
API_NAME=remove-ai-flavor-api
API_VERSION=0.1
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True

######## 存储 ########
# 数据库配置
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
POSTGRES_DB=remove-ai-flavor-test
POSTGRES_EXPOSE_PORT=15433

# Redis 配置
REDIS_PASSWORD=123456
REDIS_EXPOSE_PORT=16380

######## 通知 ########
# send mail (SMTP/RESEND)
MAIL_SEND_METHOD=SMTP

# smtp (大多数云厂商可能会封禁)
MAIL_USERNAME=test@example.com
MAIL_PASSWORD=test123456
MAIL_FROM=test@example.com
MAIL_PORT=587
MAIL_SERVER=smtp.example.com

# 或使用 Resend，先修改 MAIL_SEND_METHOD=Resend
RESEND_API_KEY=re_test_xxxxx
RESEND_MAIL_FROM=onboarding@resend.dev

######## 大模型与 Agent ########
# AI Agent 配置
AGENT_API_KEY=sk-test-xxxxx
AGENT_BASE_URL=https://api.openai.com/v1/chat/completions
AGENT_MODEL_NAME=gpt-4o-mini

######## 会员与支付 ########
# stripe pay
STRIPE_PUBLIC_KEY=pk_test_xxxxx
STRIPE_PRIVATE_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_test_xxxxx

