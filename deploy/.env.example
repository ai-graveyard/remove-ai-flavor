# ====================================
# 生产环境配置文件
# ====================================

######## 环境与服务 ########
# env
ENV=prod

# Docker 配置
DOCKER_REGISTRY=v2ai
IMAGE_PREFIX=remove-ai-flavor
IMAGE_SUFFIX=
VERSION=latest

# 容器和网络命名
CONTAINER_PREFIX=remove-ai-flavor
CONTAINER_SUFFIX=
NETWORK_NAME=remove-ai-flavor-network

# 前端构建参数
NEXT_PUBLIC_API_URL=https://www.remove-ai-flavor.com
NEXT_PUBLIC_APP_URL=https://www.remove-ai-flavor.com

# Nginx 配置
NGINX_PORT=8081
NGINX_SERVER_NAME=localhost

# 认证配置
AUTH_SECRET_KEY=your_secure_secret_key_here
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_IS_DEBUG=False

# API 配置
API_NAME=remove-ai-flavor-api
API_VERSION=0.1
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=False

######## 存储 ########
# 数据库配置
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=remove-ai-flavor
POSTGRES_EXPOSE_PORT=15432

# Redis 配置
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_EXPOSE_PORT=16379

######## 通知 ########
# send mail (SMTP/RESEND)
MAIL_SEND_METHOD=SMTP

# smtp (大多数云厂商可能会封禁)
MAIL_USERNAME=no-reply@remove-ai-flavor.com
MAIL_PASSWORD=your_mail_password_here
MAIL_FROM=no-reply@remove-ai-flavor.com
MAIL_PORT=587
MAIL_SERVER=smtp.example.com

# 或使用 Resend，先修改 MAIL_SEND_METHOD=Resend
RESEND_API_KEY=re_xxxxx
RESEND_MAIL_FROM=onboarding@resend.dev

######## 大模型与 Agent ########
# AI Agent 配置
AGENT_API_KEY=sk-proj-xxxxx
AGENT_BASE_URL=https://api.openai.com/v1/chat/completions
AGENT_MODEL_NAME=gpt-4-turbo

######## 会员与支付 ########
# stripe pay
STRIPE_PUBLIC_KEY=pk_test_xxx
STRIPE_PRIVATE_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_cexxx

# membership plan
MEMBERSHIP_FREE_NAME=免费会员
MEMBERSHIP_FREE_DAILY_MESSAGE_LIMIT=10
MEMBERSHIP_FREE_DAILY_TOKEN_LIMIT=100000
MEMBERSHIP_FREE_CONVERSATION_TURN_LIMIT=10
MEMBERSHIP_FREE_PRICE=0.0
MEMBERSHIP_FREE_CURRENCY=USD
MEMBERSHIP_FREE_DURATION_DAYS=36500
MEMBERSHIP_FREE_DESCRIPTION=免费用户基础计划

# membership plan
MEMBERSHIP_MONTHLY_NAME=月度会员
MEMBERSHIP_MONTHLY_DAILY_MESSAGE_LIMIT=100
MEMBERSHIP_MONTHLY_DAILY_TOKEN_LIMIT=1000000
MEMBERSHIP_MONTHLY_CONVERSATION_TURN_LIMIT=30
MEMBERSHIP_MONTHLY_PRICE=9.9
MEMBERSHIP_MONTHLY_CURRENCY=USD
MEMBERSHIP_MONTHLY_DURATION_DAYS=30
MEMBERSHIP_MONTHLY_DESCRIPTION=月度付费会员计划

# membership plan
MEMBERSHIP_YEARLY_NAME=年度会员
MEMBERSHIP_YEARLY_DAILY_MESSAGE_LIMIT=1000
MEMBERSHIP_YEARLY_DAILY_TOKEN_LIMIT=2000000
MEMBERSHIP_YEARLY_CONVERSATION_TURN_LIMIT=50
MEMBERSHIP_YEARLY_PRICE=99.9
MEMBERSHIP_YEARLY_CURRENCY=USD
MEMBERSHIP_YEARLY_DURATION_DAYS=365
MEMBERSHIP_YEARLY_DESCRIPTION=年度付费会员计划
