# API 路由语言设置规范

本项目支持国际化，前端和后端都需要正确处理语言设置。

## 后端 API 语言处理

### 1. 后端国际化配置

后端使用 `Accept-Language` HTTP 头来确定响应语言。相关配置在 [api/app/core/i18n.py](mdc:api/app/core/i18n.py) 中。

### 2. 在路由中获取语言

```python
from fastapi import APIRouter, Request, Depends
from app.core.i18n import get_locale

router = APIRouter()

@router.get("/messages")
async def get_messages(
    request: Request,
    locale: str = Depends(get_locale)
):
    """
    获取消息列表。
    
    - 参数:
      - locale: 从请求头自动解析的语言代码 ('zh' 或 'en')
    - 响应:
      - 根据语言返回对应的消息内容
    """
    # 使用 locale 返回对应语言的内容
    if locale == 'zh':
        return {"message": "你好"}
    else:
        return {"message": "Hello"}
```

### 3. 错误消息国际化

**在异常中返回多语言错误消息**:

```python
from fastapi import HTTPException
from app.core.i18n import get_locale

ERROR_MESSAGES = {
    "USER_NOT_FOUND": {
        "zh": "用户不存在",
        "en": "User not found"
    },
    "INVALID_CREDENTIALS": {
        "zh": "邮箱或密码错误",
        "en": "Invalid email or password"
    }
}

def raise_error(error_code: str, locale: str):
    """抛出国际化的错误"""
    message = ERROR_MESSAGES.get(error_code, {}).get(locale, "Unknown error")
    raise HTTPException(status_code=400, detail=message)

@router.post("/login")
async def login(
    credentials: LoginCredentials,
    locale: str = Depends(get_locale)
):
    user = authenticate_user(credentials.email, credentials.password)
    if not user:
        raise_error("INVALID_CREDENTIALS", locale)
    return {"token": create_token(user)}
```

### 4. 邮件模板国际化

**根据用户语言发送对应的邮件**:

```python
from app.services.email_service import EmailService

async def send_verification_email(user_email: str, code: str, locale: str):
    """
    发送验证码邮件。
    
    - 参数:
      - user_email: 用户邮箱
      - code: 验证码
      - locale: 语言代码
    """
    # 根据语言选择模板
    if locale == 'zh':
        template = 'email_code_login_mail_template_zh.html'
        subject = '登录验证码'
    else:
        template = 'email_code_login_mail_template_en.html'
        subject = 'Login Verification Code'
    
    await EmailService.send_email(
        to=user_email,
        subject=subject,
        template=template,
        context={'code': code}
    )
```

## 前端 API 调用中的语言设置

### 1. 在 Fetcher 中添加语言头

**所有 API 请求都应包含 `Accept-Language` 头** (参考 [web/util/fetcher.ts](mdc:web/util/fetcher.ts)):

```typescript
import { useLocale } from 'next-intl'

export function useFetcher() {
  const locale = useLocale()
  
  const fetcher = async (url: string, options: RequestInit = {}) => {
    const response = await fetch(url, {
      ...options,
      headers: {
        'Content-Type': 'application/json',
        'Accept-Language': locale, // 添加语言头
        ...options.headers
      }
    })
    
    if (!response.ok) {
      const error = await response.json()
      throw new Error(error.detail || 'Request failed')
    }
    
    return response.json()
  }
  
  return fetcher
}
```

### 2. 在组件中使用

```typescript
'use client'

import { useLocale } from 'next-intl'
import { useFetcher } from '@/util/fetcher'

export function MyComponent() {
  const locale = useLocale()
  const fetcher = useFetcher()
  
  const fetchData = async () => {
    try {
      // fetcher 会自动添加 Accept-Language 头
      const data = await fetcher('/api/v1/users')
      console.log(data)
    } catch (error) {
      // 错误消息已经是对应语言
      console.error(error.message)
    }
  }
  
  return <button onClick={fetchData}>加载数据</button>
}
```

### 3. 服务端组件中的 API 调用

```typescript
import { getLocale } from 'next-intl/server'

export default async function ServerComponent() {
  const locale = await getLocale()
  
  const response = await fetch('https://api.example.com/data', {
    headers: {
      'Accept-Language': locale
    }
  })
  
  const data = await response.json()
  return <div>{data.message}</div>
}
```

### 4. API 工具函数示例

创建统一的 API 调用工具 (参考 [web/util/user-api.ts](mdc:web/util/user-api.ts)):

```typescript
import { getAuthToken } from './token'

interface FetchOptions extends RequestInit {
  locale?: string
}

export async function apiRequest(
  endpoint: string,
  options: FetchOptions = {}
) {
  const { locale, ...fetchOptions } = options
  
  const headers: HeadersInit = {
    'Content-Type': 'application/json',
    ...fetchOptions.headers
  }
  
  // 添加认证 Token
  const token = getAuthToken()
  if (token) {
    headers['Authorization'] = `Bearer ${token}`
  }
  
  // 添加语言设置
  if (locale) {
    headers['Accept-Language'] = locale
  }
  
  const response = await fetch(`${process.env.NEXT_PUBLIC_API_URL}${endpoint}`, {
    ...fetchOptions,
    headers
  })
  
  if (!response.ok) {
    const error = await response.json()
    throw new Error(error.detail || 'API request failed')
  }
  
  return response.json()
}

// 使用示例
export async function getUserProfile(locale: string) {
  return apiRequest('/api/v1/users/me', {
    method: 'GET',
    locale
  })
}
```

## 最佳实践

### 1. 语言代码规范

- 使用 ISO 639-1 标准: `zh` (中文), `en` (英文)
- 前后端保持一致
- 默认语言: `zh`

### 2. 错误处理

**前端应正确处理和显示后端返回的错误消息**:

```typescript
import { useTranslations } from 'next-intl'

export function useApiError() {
  const t = useTranslations('errors')
  
  const handleError = (error: Error) => {
    // 后端返回的错误消息已经是对应语言
    // 但可以在前端添加额外的处理
    const message = error.message || t('unknownError')
    
    // 显示错误提示
    toast.error(message)
  }
  
  return { handleError }
}
```

### 3. 缓存注意事项

**API 响应应该根据语言分别缓存**:

```typescript
export function useCachedData(locale: string) {
  const cacheKey = `data_${locale}` // 根据语言区分缓存
  
  // 从缓存获取
  const cached = localStorage.getItem(cacheKey)
  if (cached) {
    return JSON.parse(cached)
  }
  
  // 请求数据并缓存
  const data = await fetchData(locale)
  localStorage.setItem(cacheKey, JSON.stringify(data))
  return data
}
```

### 4. 语言切换后刷新数据

```typescript
'use client'

import { useLocale } from 'next-intl'
import { useEffect } from 'react'
import { useRouter } from 'next/navigation'

export function LanguageSwitcher() {
  const locale = useLocale()
  const router = useRouter()
  
  const switchLanguage = (newLocale: string) => {
    // 切换语言后刷新页面，确保所有数据使用新语言
    router.push(`/${newLocale}${window.location.pathname}`)
    router.refresh()
  }
  
  return (
    <select value={locale} onChange={(e) => switchLanguage(e.target.value)}>
      <option value="zh">中文</option>
      <option value="en">English</option>
    </select>
  )
}
```

## 测试

### 前端测试

```typescript
import { render } from '@testing-library/react'
import { NextIntlClientProvider } from 'next-intl'

test('renders component with correct language', () => {
  const messages = {
    title: '标题'
  }
  
  render(
    <NextIntlClientProvider locale="zh" messages={messages}>
      <MyComponent />
    </NextIntlClientProvider>
  )
})
```

### 后端测试

```python
from fastapi.testclient import TestClient

def test_api_with_language():
    """测试 API 语言处理"""
    # 中文请求
    response = client.get(
        "/api/v1/users",
        headers={"Accept-Language": "zh"}
    )
    assert response.json()["message"] == "用户列表"
    
    # 英文请求
    response = client.get(
        "/api/v1/users",
        headers={"Accept-Language": "en"}
    )
    assert response.json()["message"] == "User list"
```
